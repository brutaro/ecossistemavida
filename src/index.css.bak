@import url('https://fonts.googleapis.com/css2?family=Libre+Caslon+Text:ital,wght@0,400;0,700;1,400&family=Work+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap');
@import "tailwindcss";

@theme {
  --font-display: "Libre Caslon Text", "Playfair Display", Georgia, serif;
  --font-sans: "Work Sans", "Inter", sans-serif;
  
  --color-forest-deep: #0D3524;
  --color-forest-dark: #082418;
  --color-champagne-gold: #C59B4E;
  --color-clay-earth: #B36E4D;
  --color-court-white: #F7F5F0;
  --color-tennis-yellow: #D4E12D;
  
  --color-surface-tint: #406652;
  --color-primary-dark: #001f12;
  --color-primary-container: #0d3524;
  --color-on-primary-container: #779f88;
  --color-secondary-dark: #7a580f;
  --color-secondary-container: #ffd07e;
  --color-on-secondary-container: #79570e;
}

/* Glassmorphism custom utilities */
.glass-panel {
  background: rgba(13, 53, 36, 0.45);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba(197, 155, 78, 0.2);
}

.glass-panel-light {
  background: rgba(247, 245, 240, 0.75);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba(179, 110, 77, 0.15);
}

.glass-card {
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border: 1px solid rgba(197, 155, 78, 0.15);
  transition: all 0.3s ease;
}

.glass-card:hover {
  background: rgba(255, 255, 255, 0.14);
  border-color: rgba(197, 155, 78, 0.35);
  box-shadow: 0 10px 25px -5px rgba(8, 36, 24, 0.25);
}

/* Smooth scroll behavior */
html {
  scroll-behavior: smooth;
}
